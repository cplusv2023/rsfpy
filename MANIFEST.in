# MANIFEST.in

# 包含许可证、README 和依赖列表
include LICENSE
include README.md
include requirements.txt
include test/dat.test
include scripts/*.sh

# 包含 Python 和 native source，确保 sdist 可以编译扩展和可选工具
recursive-include src/rsfpy *.py *.c *.h *.m

# 包含测试文件
recursive-include test *.py

# 排除本地构建产物
prune build

# 排除虚拟环境文件
global-exclude *.py[cod]
global-exclude __pycache__/*
